    private List<PropertyModel> FilteredProperties { get; set; } = new();

    // ── Lifecycle ─────────────────────────────────────────────────────────────
    protected override void OnInitialized() => ApplyFilters();

    // ── Filter logic ──────────────────────────────────────────────────────────
    private void ApplyFilters()
    {
        var selectedTypes = SelectedPropertyTypes.Select(x => x.Text).ToHashSet();
        var requiredAmenities = AmenityItems.Where(a => a.IsChecked).Select(a => a.Name).ToHashSet();

        var results = AllProperties.Where(p =>
            (string.IsNullOrWhiteSpace(FilterKw) ||
                p.Title.Contains(FilterKw, StringComparison.OrdinalIgnoreCase) ||
                p.Address.Contains(FilterKw, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrWhiteSpace(FilterLocation) ||
                p.Address.Contains(FilterLocation, StringComparison.OrdinalIgnoreCase)) &&
            p.Price >= PriceMin && p.Price <= PriceMax &&
            p.Bedrooms >= BedsMin && p.Bedrooms <= BedsMax &&
            p.Bathrooms >= BathsMin && p.Bathrooms <= BathsMax &&
            p.SqFt >= SqFtMin && p.SqFt <= SqFtMax &&
            p.LotAcres >= LotMin && p.LotAcres <= LotMax &&
            p.YearBuilt >= YearMin && p.YearBuilt <= YearMax &&
            (!selectedTypes.Any() || selectedTypes.Contains(p.PropertyType)) &&
            (!requiredAmenities.Any() || requiredAmenities.All(a => p.Amenities.Contains(a)))
        );

        FilteredProperties = SortResults(results).ToList();
    }

    private void ResetFilters()
    {
        FilterKw = "";
        FilterLocation = "";
        PriceMin = 100_000;    PriceMax = 1_500_000;
        BedsMin = 0;           BedsMax = 8;
        BathsMin = 1;          BathsMax = 6;
        SqFtMin = 0;           SqFtMax = 6000;
        LotMin = 0.0m;         LotMax = 5.0m;
        YearMin = 1960;        YearMax = 2025;
        SelectedPropertyTypes = new List<ChipItem>();
        foreach (var a in AmenityItems) a.IsChecked = false;
        SortMode = "best";
        ApplyFilters();
    }

    // ── Sort ──────────────────────────────────────────────────────────────────
    private void SetSort(string mode)
    {
        SortMode = mode;
        FilteredProperties = SortResults(FilteredProperties).ToList();
    }

    private void TogglePriceSort()
    {
        SortMode = SortMode == "price-asc" ? "price-desc" : "price-asc";
        FilteredProperties = SortResults(FilteredProperties).ToList();
    }

    private IEnumerable<PropertyModel> SortResults(IEnumerable<PropertyModel> list) =>
        SortMode switch
        {
            "top"        => list.OrderByDescending(p => p.TopSelling).ThenByDescending(p => p.MatchScore),
            "price-asc"  => list.OrderBy(p => p.Price),
            "price-desc" => list.OrderByDescending(p => p.Price),
            _            => list.OrderByDescending(p => p.MatchScore),   // "best"
        };

    // ── UI helpers ────────────────────────────────────────────────────────────
    private static string FormatSliderPrice(int price) =>
        price >= 1_000_000
            ? $"${price / 1_000_000.0:F2}M"
            : $"${price / 1000}K";

    private static string FormatCardPrice(int price) => $"${price:N0}";

    private void ToggleMobileFilter() => ShowMobileFilter = !ShowMobileFilter;
}
