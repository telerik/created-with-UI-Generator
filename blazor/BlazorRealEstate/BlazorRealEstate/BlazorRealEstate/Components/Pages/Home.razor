@page "/"

<PageTitle>Real Estate Search | Find Your Dream Home</PageTitle>

<div class="re-page">

    <!-- Mobile filter toggle -->
    <div class="re-mobile-toggle">
        <TelerikButton OnClick="@ToggleMobileFilter"
                       Icon="@SvgIcon.FilterSmall"
                       ThemeColor="@ThemeConstants.Button.ThemeColor.Primary">
            @(ShowMobileFilter ? "Hide Filters" : "Show Filters")
        </TelerikButton>
    </div>

    <div class="re-layout">

        <!-- ═══════════════ FILTER SIDEBAR ═══════════════ -->
        <aside class="re-sidebar @(ShowMobileFilter ? "re-sidebar--open" : "")">
            <div class="re-filter-panel">

                <h2 class="re-filter-heading">
                    <TelerikSvgIcon Icon="@SvgIcon.FilterSmall" /> Search Filters
                </h2>

                <!-- Keyword -->
                <div class="re-filter-group">
                    <label class="re-filter-label">Keywords</label>
                    <TelerikTextBox @bind-Value="@FilterKw"
                                    Placeholder="e.g. pool, open floor plan…"
                                    Width="100%" />
                </div>

                <!-- Location -->
                <div class="re-filter-group">
                    <label class="re-filter-label">Location</label>
                    <TelerikTextBox @bind-Value="@FilterLocation"
                                    Placeholder="City, ZIP, or neighborhood"
                                    Width="100%" />
                </div>

                <!-- Price Range -->
                <div class="re-filter-group">
                    <label class="re-filter-label">Price Range</label>
                    <div class="re-range-display">
                        <span>@FormatSliderPrice(PriceMin)</span>
                        <span>@FormatSliderPrice(PriceMax)</span>
                    </div>
                    <TelerikRangeSlider Min="0" Max="2000000"
                                        SmallStep="10000"
                                        LargeStep="500000"
                                        Class="re-slider"
                                        @bind-StartValue="@PriceMin"
                                        @bind-EndValue="@PriceMax" />
                </div>

                <!-- Property Type -->
                <div class="re-filter-group">
                    <label class="re-filter-label">Property Type</label>
                    <TelerikChipList Data="@PropertyTypes"
                                     TextField="@nameof(ChipItem.Text)"
                                     SelectionMode="@ChipListSelectionMode.Multiple"
                                     @bind-SelectedItems="@SelectedPropertyTypes" />
                </div>

                <!-- Bedrooms -->
                <div class="re-filter-group">
                    <label class="re-filter-label">Bedrooms</label>
                    <div class="re-range-display">
                        <span>@BedsMin bd</span>
                        <span>@BedsMax bd</span>
                    </div>
                    <TelerikRangeSlider Min="0" Max="8"
                                        SmallStep="1"
                                        LargeStep="4"
                                        Class="re-slider"
                                        @bind-StartValue="@BedsMin"
                                        @bind-EndValue="@BedsMax" />
                </div>

                <!-- Bathrooms -->
                <div class="re-filter-group">
                    <label class="re-filter-label">Bathrooms</label>
                    <div class="re-range-display">
                        <span>@BathsMin ba</span>
                        <span>@BathsMax ba</span>
                    </div>
                    <TelerikRangeSlider Min="1" Max="6"
                                        SmallStep="1"
                                        LargeStep="3"
                                        Class="re-slider"
                                        @bind-StartValue="@BathsMin"
                                        @bind-EndValue="@BathsMax" />
                </div>

                <!-- Square Footage -->
                <div class="re-filter-group">
                    <label class="re-filter-label">Square Footage</label>
                    <div class="re-range-display">
                        <span>@SqFtMin.ToString("N0") sqft</span>
                        <span>@SqFtMax.ToString("N0") sqft</span>
                    </div>
                    <TelerikRangeSlider Min="0" Max="6000"
                                        SmallStep="100"
                                        LargeStep="1000"
                                        Class="re-slider"
                                        @bind-StartValue="@SqFtMin"
                                        @bind-EndValue="@SqFtMax" />
                </div>

                <!-- Lot Size -->
                <div class="re-filter-group">
                    <label class="re-filter-label">Lot Size (acres)</label>
                    <div class="re-range-display">
                        <span>@LotMin.ToString("F1") ac</span>
                        <span>@LotMax.ToString("F1") ac</span>
                    </div>
                    <TelerikRangeSlider Min="0.0m" Max="5.0m"
                                        SmallStep="0.1m"
                                        LargeStep="1.0m"
                                        Class="re-slider"
                                        @bind-StartValue="@LotMin"
                                        @bind-EndValue="@LotMax" />
                </div>

                <!-- Year Built -->
                <div class="re-filter-group">
                    <label class="re-filter-label">Year Built</label>
                    <div class="re-range-display">
                        <span>@YearMin</span>
                        <span>@YearMax</span>
                    </div>
                    <TelerikRangeSlider Min="1960" Max="2025"
                                        SmallStep="1"
                                        LargeStep="10"
                                        Class="re-slider"
                                        @bind-StartValue="@YearMin"
                                        @bind-EndValue="@YearMax" />
                </div>

                <!-- Amenities (collapsible) -->
                <div class="re-filter-group">
                    <TelerikPanelBar Data="@AmenityPanelData"
                                     ExpandMode="@PanelBarExpandMode.Single"
                                     @bind-ExpandedItems="@AmenityExpanded">
                        <PanelBarBindings>
                            <PanelBarBinding Level="0" TextField="@nameof(PanelItem.Text)">
                                <ContentTemplate>
                                    <div class="re-amenities-grid">
                                        @foreach (var amenity in AmenityItems)
                                        {
                                            var aid = amenity.Id;
                                            <div class="re-amenity-row">
                                                <TelerikCheckBox @bind-Value="@amenity.IsChecked"
                                                                 Id="@aid" />
                                                <label for="@aid">@amenity.Name</label>
                                            </div>
                                        }
                                    </div>
                                </ContentTemplate>
                            </PanelBarBinding>
                        </PanelBarBindings>
                    </TelerikPanelBar>
                </div>

                <!-- Actions -->
                <div class="re-filter-actions">
                    <TelerikButton ThemeColor="@ThemeConstants.Button.ThemeColor.Primary"
                                   OnClick="@ApplyFilters"
                                   Class="re-btn-full">
                        Search Properties
                    </TelerikButton>
                    <TelerikButton FillMode="@ThemeConstants.Button.FillMode.Outline"
                                   OnClick="@ResetFilters"
                                   Class="re-btn-full">
                        Clear Filters
                    </TelerikButton>
                </div>

            </div>
        </aside>

        <!-- ═══════════════ RESULTS PANEL ═══════════════ -->
        <section class="re-results">

            <!-- Sort bar -->
            <div class="re-sort-bar">
                <span class="re-result-count">@FilteredProperties.Count @(FilteredProperties.Count == 1 ? "property" : "properties") found</span>
                <div class="re-sort-group">
                    <span class="re-sort-label">Sort:</span>
                    <TelerikButton Size="@ThemeConstants.Button.Size.Small"
                                   FillMode="@(SortMode == "best" ? ThemeConstants.Button.FillMode.Solid : ThemeConstants.Button.FillMode.Outline)"
                                   ThemeColor="@(SortMode == "best" ? ThemeConstants.Button.ThemeColor.Primary : ThemeConstants.Button.ThemeColor.Base)"
                                   OnClick="@(() => SetSort("best"))">
                        Best Match
                    </TelerikButton>
                    <TelerikButton Size="@ThemeConstants.Button.Size.Small"
                                   FillMode="@(SortMode == "top" ? ThemeConstants.Button.FillMode.Solid : ThemeConstants.Button.FillMode.Outline)"
                                   ThemeColor="@(SortMode == "top" ? ThemeConstants.Button.ThemeColor.Primary : ThemeConstants.Button.ThemeColor.Base)"
                                   OnClick="@(() => SetSort("top"))">
                        Top Selling
                    </TelerikButton>
                    <TelerikButton Size="@ThemeConstants.Button.Size.Small"
                                   FillMode="@(SortMode.StartsWith("price") ? ThemeConstants.Button.FillMode.Solid : ThemeConstants.Button.FillMode.Outline)"
                                   ThemeColor="@(SortMode.StartsWith("price") ? ThemeConstants.Button.ThemeColor.Primary : ThemeConstants.Button.ThemeColor.Base)"
                                   OnClick="@TogglePriceSort">
                        Price @(SortMode == "price-asc" ? "↑" : SortMode == "price-desc" ? "↓" : "")
                    </TelerikButton>
                </div>
            </div>

            <!-- Property cards -->
            <div class="re-card-grid">
                @foreach (var p in FilteredProperties)
                {
                    <TelerikCard Class="re-prop-card">
                        <CardImage Src="@p.ImageUrl" />
                        <CardBody>
                            <div class="re-card-price">@FormatCardPrice(p.Price)</div>
                            <CardTitle>@p.Title</CardTitle>
                            <p class="re-card-address">
                                <TelerikSvgIcon Icon="@SvgIcon.BuildingsSolid" />
                                @p.Address
                            </p>
                            <div class="re-card-meta">
                                <span class="re-card-stat">
                                    <TelerikSvgIcon Icon="@SvgIcon.BedSolid" />
                                    @p.Bedrooms bd
                                </span>
                                <span class="re-card-stat">
                                    <TelerikSvgIcon Icon="@SvgIcon.BathtubeSolid" />
                                    @p.Bathrooms ba
                                </span>
                                <span class="re-card-stat">
                                    <TelerikSvgIcon Icon="@SvgIcon.Area" />
                                    @p.SqFt.ToString("N0") sqft
                                </span>
                            </div>
                        </CardBody>
                    </TelerikCard>
                }
                @if (FilteredProperties.Count == 0)
                {
                    <div class="re-no-results">
                        <p>No properties match your current filters.</p>
                        <TelerikButton ThemeColor="@ThemeConstants.Button.ThemeColor.Primary"
                                       OnClick="@ResetFilters">Clear Filters</TelerikButton>
                    </div>
                }
            </div>
        </section>

    </div>
</div>

<style>
    /* ── Page shell ── */
    .re-page {
        padding: 1rem 1.25rem;
    }

    .re-mobile-toggle {
        display: none;
        margin-bottom: 1rem;
    }

    /* ── Golden-ratio two-column layout ── */
    .re-layout {
        display: grid;
        grid-template-columns: 1fr 1.618fr;
        gap: 1.5rem;
        align-items: start;
    }

    /* ── Filter sidebar ── */
    .re-sidebar {
        position: sticky;
        top: 1rem;
    }

    .re-filter-panel {
        background: var(--kendo-color-surface-alt, #f9f9f9);
        border: 1px solid var(--kendo-color-border, #e0e0e0);
        border-radius: var(--kendo-border-radius-lg, 8px);
        padding: 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .re-filter-heading {
        font-size: 1.05rem;
        font-weight: 700;
        margin: 0 0 0.25rem;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    .re-filter-group {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
    }

    .re-filter-label {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--kendo-color-on-base, #555);
    }

    .re-range-display {
        display: flex;
        justify-content: space-between;
        font-size: 0.88rem;
        font-weight: 600;
        color: var(--kendo-color-primary, #ff6358);
    }

    /* Hide slider graduation marks / tick labels */
    .re-slider .k-tick,
    .re-slider .k-tick-sm,
    .re-slider .k-label {
        display: none;
    }

    .re-slider {
        width: 100%;
    }

    /* Amenities panel (inside PanelBar content) */
    .re-amenities-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.35rem 0.75rem;
        padding: 0.5rem 0.25rem 0.25rem;
    }

    .re-amenity-row {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        font-size: 0.88rem;
    }

    .re-amenity-row label {
        cursor: pointer;
    }

    .re-filter-actions {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        padding-top: 0.25rem;
    }

    .re-btn-full {
        width: 100%;
    }

    .re-btn-full.k-button {
        width: 100%;
    }

    /* ── Results section ── */
    .re-results {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .re-sort-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.75rem;
        padding: 0.65rem 1rem;
        background: var(--kendo-color-surface-alt, #f9f9f9);
        border: 1px solid var(--kendo-color-border, #e0e0e0);
        border-radius: var(--kendo-border-radius-md, 6px);
    }

    .re-result-count {
        font-size: 0.88rem;
        color: var(--kendo-color-subtle, #777);
    }

    .re-sort-group {
        display: flex;
        align-items: center;
        gap: 0.35rem;
    }

    .re-sort-label {
        font-size: 0.82rem;
        color: var(--kendo-color-subtle, #777);
    }

    /* ── Property card grid ── */
    .re-card-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
        gap: 1.25rem;
    }

    .re-prop-card {
        cursor: pointer;
        overflow: hidden;
        transition: box-shadow 0.2s ease, transform 0.2s ease;
    }

    .re-prop-card:hover {
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.13);
        transform: translateY(-3px);
    }

    .re-prop-card .k-card-image {
        height: 185px;
        object-fit: cover;
        width: 100%;
        display: block;
    }

    .re-card-price {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--kendo-color-primary, #ff6358);
        margin-bottom: 0.2rem;
    }

    .re-prop-card .k-card-title {
        font-size: 1rem;
        font-weight: 700;
        margin: 0.2rem 0 0.5rem;
    }

    .re-card-address {
        display: flex;
        align-items: center;
        gap: 0.3rem;
        font-size: 0.83rem;
        color: var(--kendo-color-subtle, #777);
        margin: 0 0 0.75rem;
    }

    .re-card-meta {
        display: flex;
        gap: 0.9rem;
        flex-wrap: wrap;
    }

    .re-card-stat {
        display: flex;
        align-items: center;
        gap: 0.3rem;
        font-size: 0.85rem;
        font-weight: 600;
    }

    /* ── No results ── */
    .re-no-results {
        grid-column: 1 / -1;
        text-align: center;
        padding: 3rem 1rem;
        color: var(--kendo-color-subtle, #777);
    }

    /* ── Mobile ── */
    @@media (max-width: 768px) {
        .re-mobile-toggle {
            display: block;
        }

        .re-layout {
            grid-template-columns: 1fr;
        }

        .re-sidebar {
            display: none;
            position: static;
        }

        .re-sidebar.re-sidebar--open {
            display: block;
        }
    }
</style>

